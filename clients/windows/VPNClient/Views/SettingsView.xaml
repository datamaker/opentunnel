<UserControl x:Class="VPNClient.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignWidth="450" d:DesignHeight="700"
             Background="{StaticResource BackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource CardBackgroundBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                Padding="20,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Style="{StaticResource IconButtonStyle}"
                        Click="CloseButton_Click" ToolTip="Back">
                    <TextBlock Text="&#xE72B;" FontFamily="Segoe MDL2 Assets" FontSize="16"/>
                </Button>

                <TextBlock Grid.Column="1" Text="Settings" FontSize="18" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           VerticalAlignment="Center" Margin="12,0,0,0"/>
            </Grid>
        </Border>

        <!-- Body -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24">

                <!-- General -->
                <TextBlock Text="GENERAL" FontSize="12" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="4,0,0,8"/>

                <Border Background="#F9F9F9" CornerRadius="6" Padding="16" Margin="0,0,0,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="Start with Windows" FontSize="14"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="Launch OpenTunnel when Windows starts"
                                       FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                        <CheckBox x:Name="StartWithWindowsCheckBox" Grid.Column="1"
                                  VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <Border Background="#F9F9F9" CornerRadius="6" Padding="16" Margin="0,0,0,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="Auto-connect on startup" FontSize="14"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="Automatically connect to last server"
                                       FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                        <CheckBox x:Name="AutoConnectCheckBox" Grid.Column="1"
                                  VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <Border Background="#F9F9F9" CornerRadius="6" Padding="16" Margin="0,0,0,24">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="Minimize to system tray" FontSize="14"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="Minimize to tray instead of taskbar"
                                       FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                        <CheckBox x:Name="MinimizeToTrayCheckBox" Grid.Column="1"
                                  VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- Connection -->
                <TextBlock Text="CONNECTION" FontSize="12" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="4,0,0,8"/>

                <Border Background="#F9F9F9" CornerRadius="6" Padding="16" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="MTU Size" FontSize="14"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>
                            <Slider x:Name="MtuSlider" Minimum="576" Maximum="1500"
                                    Value="1400" TickFrequency="100" IsSnapToTickEnabled="True"
                                    VerticalAlignment="Center"/>
                            <TextBox x:Name="MtuTextBox" Grid.Column="1"
                                     Style="{StaticResource ModernTextBoxStyle}"
                                     Text="1400" TextAlignment="Center"
                                     Margin="12,0,0,0" TextChanged="MtuTextBox_TextChanged"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Background="#F9F9F9" CornerRadius="6" Padding="16" Margin="0,0,0,24">
                    <StackPanel>
                        <TextBlock Text="Custom DNS (optional)" FontSize="14"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                        <TextBox x:Name="CustomDnsTextBox"
                                 Style="{StaticResource ModernTextBoxStyle}"
                                 Text="" ToolTip="e.g., 1.1.1.1, 8.8.8.8"/>
                        <TextBlock Text="Comma-separated DNS servers. Leave empty to use server-provided DNS."
                                   FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                   TextWrapping="Wrap" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Security -->
                <TextBlock Text="SECURITY" FontSize="12" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="4,0,0,8"/>

                <Border Background="#F9F9F9" CornerRadius="6" Padding="16" Margin="0,0,0,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="Kill switch" FontSize="14"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="Block internet if VPN disconnects"
                                       FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                        <CheckBox x:Name="KillSwitchCheckBox" Grid.Column="1"
                                  VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <Border Background="#F9F9F9" CornerRadius="6" Padding="16" Margin="0,0,0,24">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="Enable logging" FontSize="14"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="Log connection events for troubleshooting"
                                       FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                        <CheckBox x:Name="EnableLoggingCheckBox" Grid.Column="1"
                                  VerticalAlignment="Center" IsChecked="True"/>
                    </Grid>
                </Border>

                <!-- Advanced -->
                <TextBlock Text="ADVANCED" FontSize="12" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="4,0,0,8"/>

                <Border Background="#F9F9F9" CornerRadius="6" Padding="16" Margin="0,0,0,24">
                    <StackPanel>
                        <TextBlock Text="Connection timeout (seconds)" FontSize="14"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                        <TextBox x:Name="TimeoutTextBox"
                                 Style="{StaticResource ModernTextBoxStyle}"
                                 Text="30" Width="100" HorizontalAlignment="Left"/>
                    </StackPanel>
                </Border>

                <!-- About -->
                <TextBlock Text="ABOUT" FontSize="12" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="4,0,0,8"/>

                <Border Background="#F9F9F9" CornerRadius="6" Padding="16" Margin="0,0,0,24">
                    <StackPanel>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Version" FontSize="14"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Grid.Column="1" Text="1.0.0" FontSize="14" TextAlignment="Right"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                        </Grid>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Protocol" FontSize="14"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Grid.Column="1" Text="TLS 1.3" FontSize="14" TextAlignment="Right"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Platform" FontSize="14"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Grid.Column="1" Text="Windows" FontSize="14" TextAlignment="Right"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Reset / Save -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="1" Style="{StaticResource SecondaryButtonStyle}"
                            Content="Reset to Defaults" Margin="0,0,12,0"
                            Click="ResetButton_Click"/>
                    <Button Grid.Column="2" Style="{StaticResource ModernButtonStyle}"
                            Content="Save Changes" Click="SaveButton_Click"/>
                </Grid>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
