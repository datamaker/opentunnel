<UserControl x:Class="VPNClient.Views.MainView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignWidth="450" d:DesignHeight="700"
             Background="{StaticResource BackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource CardBackgroundBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                Padding="20,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Brand mark -->
                <Viewbox Grid.Column="0" Width="34" Height="34" VerticalAlignment="Center">
                    <Grid Width="24" Height="24">
                        <Path Fill="{StaticResource BrandGradientBrush}"
                              Data="M12,2 L20,5 L20,11 C20,16 16.4,20.5 12,22 C7.6,20.5 4,16 4,11 L4,5 Z"/>
                        <Path Stroke="White" StrokeThickness="1.6"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                              StrokeLineJoin="Round"
                              Data="M8.2,12 L11,14.6 L15.8,9.2"/>
                    </Grid>
                </Viewbox>

                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0,0,0">
                    <TextBlock Text="OpenTunnel" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="{Binding Username}" FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                </StackPanel>

                <!-- Settings (gear) -->
                <Button Grid.Column="2" Style="{StaticResource IconButtonStyle}"
                        Click="SettingsButton_Click" ToolTip="Settings">
                    <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="18"/>
                </Button>

                <!-- Logout -->
                <Button Grid.Column="3" Style="{StaticResource IconButtonStyle}"
                        Click="LogoutButton_Click" ToolTip="Logout" Margin="4,0,0,0">
                    <TextBlock Text="&#xE7E8;" FontFamily="Segoe MDL2 Assets" FontSize="18"/>
                </Button>
            </Grid>
        </Border>

        <!-- Body -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24">

                <!-- Connection status card -->
                <Border Style="{StaticResource CardStyle}" Padding="24,32" Margin="0,0,0,20">
                    <StackPanel HorizontalAlignment="Center">
                        <!-- Concentric status indicator -->
                        <Grid Width="120" Height="120" HorizontalAlignment="Center">
                            <Ellipse x:Name="StatusOuter" Width="120" Height="120"/>
                            <Ellipse x:Name="StatusMid" Width="90" Height="90"/>
                            <Ellipse x:Name="StatusInner" Width="60" Height="60"/>
                            <TextBlock x:Name="StatusIcon" Text="&#x2715;"
                                       FontSize="24" FontWeight="Bold" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>

                        <TextBlock x:Name="StatusTitle" Text="Disconnected"
                                   FontSize="20" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   HorizontalAlignment="Center" Margin="0,20,0,4"/>
                        <TextBlock x:Name="StatusDescription"
                                   Text="Tap Connect to secure your connection"
                                   FontSize="13" TextWrapping="Wrap" TextAlignment="Center"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Connection details (visible when connected) -->
                <Border x:Name="ConnectionDetailsCard" Style="{StaticResource CardStyle}"
                        Margin="0,0,0,20" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="Connection Details" FontSize="15" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                        <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,0,0,12"/>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Server" FontSize="13"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock x:Name="ServerValueText" Grid.Column="1" Text="--"
                                       FontSize="13" FontWeight="Medium" TextAlignment="Right"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Assigned IP" FontSize="13"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock x:Name="AssignedIpText" Grid.Column="1" Text="--"
                                       FontSize="13" FontWeight="Medium" TextAlignment="Right"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Statistics (visible when connected) -->
                <Border x:Name="StatisticsCard" Style="{StaticResource CardStyle}"
                        Margin="0,0,0,20" Visibility="Collapsed">
                    <StackPanel>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Statistics" FontSize="15" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock x:Name="DurationText" Grid.Column="1" Text="00:00:00"
                                       FontSize="13"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       VerticalAlignment="Center"/>
                        </Grid>
                        <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,0,0,16"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                <TextBlock x:Name="DownloadText" Text="0 B/s"
                                           FontSize="16" FontWeight="SemiBold"
                                           HorizontalAlignment="Center"
                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBlock Text="Downloaded" FontSize="12" Margin="0,4,0,0"
                                           HorizontalAlignment="Center"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                <TextBlock x:Name="UploadText" Text="0 B/s"
                                           FontSize="16" FontWeight="SemiBold"
                                           HorizontalAlignment="Center"
                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBlock Text="Uploaded" FontSize="12" Margin="0,4,0,0"
                                           HorizontalAlignment="Center"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Connect / Disconnect -->
                <Button x:Name="ConnectButton" Style="{StaticResource ModernButtonStyle}"
                        HorizontalAlignment="Stretch" Padding="24,16"
                        Click="ConnectButton_Click">
                    <TextBlock x:Name="ConnectButtonText" Text="Connect" FontSize="16"/>
                </Button>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
