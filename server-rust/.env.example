# VPN Server Configuration (Rust)
NODE_ENV=development

# Server
VPN_PORT=1194
VPN_HOST=0.0.0.0

# TLS Certificates
TLS_CERT_PATH=./certs/server.crt
TLS_KEY_PATH=./certs/server.key
TLS_CA_PATH=./certs/ca.crt

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=vpn
DB_USER=vpn
DB_PASSWORD=vpn_password

# VPN Network
VPN_SUBNET=10.8.0.0
VPN_NETMASK=255.255.255.0
VPN_GATEWAY=10.8.0.1
VPN_DNS=8.8.8.8,8.8.4.4
VPN_MTU=1400

# Security
JWT_SECRET=change-this-to-a-secure-random-string

# Admin panel
ADMIN_PORT=8080
ADMIN_PASSWORD=admin123

# Split tunneling (destination-based routing)
# When enabled, clients route ONLY the listed IP CIDRs and domains through the
# tunnel; all other traffic uses their normal connection. Disabled = full tunnel.
SPLIT_TUNNEL=false
SPLIT_INCLUDE_ROUTES=10.0.0.0/8,192.168.0.0/16
SPLIT_INCLUDE_DOMAINS=internal.example.com,api.example.com
SPLIT_DNS_REFRESH_SECS=300

# Logging
LOG_LEVEL=info
